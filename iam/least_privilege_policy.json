{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOnlyConfiguredSourceObject",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::replace-with-your-bucket-name/raw/covid_data.json"
    },
    {
      "Sid": "WriteOnlyConfiguredDynamoDBTable",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem",
        "dynamodb:BatchWriteItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:123456789012:table/covid_country_stats"
    },
    {
      "Sid": "CreateLogGroupWhenAbsent",
      "Effect": "Allow",
      "Action": "logs:CreateLogGroup",
      "Resource": "*"
    },
    {
      "Sid": "WriteOnlyThisFunctionLogGroup",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:123456789012:log-group:/aws/lambda/covid19-s3-lambda-dynamodb-etl:*"
    }
  ]
}

